<script>

      var fallbackLanguage = { code: "en" };

      var rawServerLang = "ir";
      var serverPreferredLangCode =
        typeof rawServerLang === "string"
          ? rawServerLang.replace(/^\s+|\s+$/g, "")
          : "";

      var browserLanguages;
      if (
        serverPreferredLangCode !== "" &&
        typeof translations[serverPreferredLangCode] !== "undefined"
      ) {
        browserLanguages = [
          { code: serverPreferredLangCode },
          ...parse(window.navigator.language),
          fallbackLanguage,
        ];
      } else {
        browserLanguages = [
          ...parse(window.navigator.language),
          fallbackLanguage,
        ];
      }

      var languageDropdown = document.getElementById("languageDropdown");
      var languageDropdownBtn = document.getElementById("languageDropdownBtn");
      var languageDropdownMenu = document.getElementById("languageDropdownMenu");
      var languageDropdownBtnFlag = document.getElementById("languageDropdownBtnFlag");
      var languageDropdownBtnLabel = document.getElementById("languageDropdownBtnLabel");

      function languageFlagUrl(langCode) {
        var iso = languageFlagIso[langCode];
        return iso ? languageFlagCdnBase + iso + ".png" : "";
      }

      function setLanguagePickerUi(langCode) {
        var label = languages[langCode] || langCode;
        var url = languageFlagUrl(langCode);
        languageDropdownBtnLabel.textContent = label;
        if (url) {
          languageDropdownBtnFlag.src = url;
          languageDropdownBtnFlag.alt = "";
          languageDropdownBtnFlag.referrerPolicy = "no-referrer";
        } else {
          languageDropdownBtnFlag.removeAttribute("src");
        }
        languageDropdownBtnFlag.style.display = url ? "" : "none";
        Array.prototype.forEach.call(languageDropdownMenu.querySelectorAll("li"), function (
          row
        ) {
          row.classList.toggle(
            "bn-cap-lang-item-active",
            row.getAttribute("data-lang") === langCode
          );
        });
      }

      function closeLanguageMenu() {
        languageDropdownMenu.hidden = true;
        languageDropdownBtn.setAttribute("aria-expanded", "false");
      }

      function openLanguageMenu() {
        languageDropdownMenu.hidden = false;
        languageDropdownBtn.setAttribute("aria-expanded", "true");
      }

      languageDropdown.addEventListener(
        "change",
        function () {
          var code = languageDropdown.value;
          setLanguagePickerUi(code);
          translate([{ code: code }, fallbackLanguage]);
        },
        false
      );

      languageDropdownBtn.addEventListener("click", function (ev) {
        ev.stopPropagation();
        if (languageDropdownMenu.hidden) {
          openLanguageMenu();
        } else {
          closeLanguageMenu();
        }
      });

      document.addEventListener("click", function () {
        closeLanguageMenu();
      });

      languageDropdownMenu.addEventListener("click", function (ev) {
        ev.stopPropagation();
      });

      document.addEventListener("keydown", function (ev) {
        if (ev.key === "Escape") {
          closeLanguageMenu();
        }
      });

      for (const langCode in translations) {
        var langLabel = languages[langCode] || langCode;
        var opt = document.createElement("option");
        opt.value = langCode;
        opt.textContent = langLabel;
        opt.selected = browserLanguages[0].code === langCode;
        languageDropdown.appendChild(opt);

        var li = document.createElement("li");
        li.setAttribute("role", "option");
        li.setAttribute("data-lang", langCode);
        var flagUrl = languageFlagUrl(langCode);
        if (flagUrl) {
          var img = document.createElement("img");
          img.className = "bn-cap-lang-item-flag";
          img.src = flagUrl;
          img.alt = "";
          img.width = 20;
          img.height = 14;
          img.loading = "lazy";
          img.decoding = "async";
          img.referrerPolicy = "no-referrer";
          li.appendChild(img);
        }
        var span = document.createElement("span");
        span.className = "bn-cap-lang-item-label";
        span.textContent = langLabel;
        li.appendChild(span);
        li.addEventListener("click", function () {
          var code = langCode;
          languageDropdown.value = code;
          languageDropdown.dispatchEvent(new Event("change", { bubbles: true }));
          closeLanguageMenu();
        });
        languageDropdownMenu.appendChild(li);
      }

      setLanguagePickerUi(languageDropdown.value);

      // More info dropdown

      var moreInfoDropdown = document.getElementById("moreInfoDropdown");
      if (moreInfoDropdown) {
        moreInfoDropdown.addEventListener(
          "click",
          function () {
            var el = document.getElementById("moreInfo");
            if (!el) return;
            if (el.className === "visible") {
              el.className = "invisible";
            } else {
              el.className = "visible";
            }
          },
          false
        );
      }
    </script>

    <script>
      var translationMap = {};

      function translate(browserLanguages) {
        if (rtlLanguages.indexOf(browserLanguages[0].code) !== -1) {
          document.body.setAttribute("dir", "rtl");
        } else {
          document.body.setAttribute("dir", "ltr");
        }

        browserLanguages.reverse().forEach((lang, idx) => {
          if (typeof translations[lang.code] !== "undefined") {
            var languageMap = translations[lang.code];

            for (const [key, value] of Object.entries(languageMap)) {
              translationMap[key] = value;
            }
          }
        });

        for (const key in translationMap) {
          if (translationMap.hasOwnProperty(key)) {
            const replace = translationMap[key];
            Array.from(
              document.getElementsByClassName("js-lang-" + key)
            ).forEach(function (element) {
              if (element) {
                element.innerHTML = replace;
              }

              if (element.value) {
                element.value = replace;
              }
            });
          }
        }
      }

      translate(browserLanguages);
    </script>
