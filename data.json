    /* Captcha page tweaks (aligned with WAF 403) */
    body.bn403-page.bn-cap-page .bn403-ip-card {
      margin-bottom: 1.25rem;
    }
    /* Larger challenge area: easier reCAPTCHA + submit (captcha page only). */
    body.bn403-page.bn-cap-page .bn403-steps-sheet {
      display: flex;
      flex-direction: column;
      min-height: clamp(16rem, 48vh, 28rem);
    }
    body.bn403-page.bn-cap-page .bn403-continue-sheet {
      flex: 1 1 auto;
      justify-content: center;
      min-height: 0;
      padding: clamp(1.75rem, 5vw, 3rem) clamp(1.25rem, 3vw, 2.25rem);
      gap: clamp(1.35rem, 3.5vw, 2.25rem);
    }
    /* Single-column CAPTCHA: one centered card (no left/right split). */
